<% layout('layouts/boilerplate') -%>
<div class="row mt-5">
  <div class="col-12 col-lg-10 offset-lg-1 col-md-11 offset-md-0">
    <div class="row">
      <!-- Left Column: Image -->
      <div class="col-lg-6 col-md-12 mb-md-4 mb-lg-0">
        <div class="card show-card listing-card border-0">
          <img
            src="<%= listing.image.url %>"
            class="card-img-top show-img"
            alt="listing_image"
          />
        </div>
      </div>

      <!-- Right Column: Details -->
      <div class="col-lg-6 col-md-12 d-flex flex-column justify-content-center">
        <h3 class="listing-title fw-bold mb-1"><%= listing.title %></h3>

        <p class="listing-description text-muted mb-4">
          <%= listing.description %>
        </p>

        <p class="price-tag fs-3 fw-bold text-dark mb-4">
          &#8377; <%= listing.price.toLocaleString("en-IN") %>
          <span class="per-night fs-6 fw-normal text-muted">/ month</span>
        </p>

        <div class="listing-details">
          <div class="info-grid row mb-4">
            <div class="col-6 mb-3">
              <div class="p-3 border rounded text-center bg-light h-100">
                <small class="text-muted d-block">Owned by</small>
                <span class="fw-bold"><%= listing.owner.username %></span>
              </div>
            </div>
            <div class="col-6 mb-3">
              <div class="p-3 border rounded text-center bg-light h-100">
                <small class="text-muted d-block">Category</small>
                <span class="fw-bold"><%= listing.category %></span>
              </div>
            </div>
            <div class="col-6 mb-3">
              <div class="p-3 border rounded text-center bg-light h-100">
                <small class="text-muted d-block">Location</small>
                <span class="fw-bold"><%= listing.location %></span>
              </div>
            </div>
            <div class="col-6 mb-3">
              <div class="p-3 border rounded text-center bg-light h-100">
                <small class="text-muted d-block">Country</small>
                <span class="fw-bold"><%= listing.country %></span>
              </div>
            </div>
          </div>

          <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="btns d-flex gap-3">
            <a
              href="/listings/<%= listing._id %>/edit"
              class="btn btn-custom-edit flex-grow-1"
              >Edit</a
            >
            <form
              action="/listings/<%= listing._id %>?_method=DELETE"
              method="POST"
              class="flex-grow-1"
            >
              <button class="btn btn-custom-delete w-100">Delete</button>
            </form>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Reviews Section -->
    <div class="mt-5 mb-5">
      <% if(currUser) { %>
      <hr />
      <h4 class="review-section-title mb-4">Leave a Review</h4>
      <div class="review-form-card p-4 border rounded shadow-sm bg-white">
        <form
          action="/listings/<%= listing._id %>/reviews"
          method="POST"
          novalidate
          class="needs-validation"
        >
          <div class="mb-3">
            <label for="rating" class="form-label fw-bold">Rating</label>
            <fieldset class="starability-slot">
              <input
                type="radio"
                id="no-rate"
                class="input-no-rate"
                name="review[rating]"
                value="1"
                checked
                aria-label="No rating."
              />
              <input
                type="radio"
                id="first-rate1"
                name="review[rating]"
                value="1"
              />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input
                type="radio"
                id="first-rate2"
                name="review[rating]"
                value="2"
              />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input
                type="radio"
                id="first-rate3"
                name="review[rating]"
                value="3"
              />
              <label for="first-rate3" title="Average">3 stars</label>
              <input
                type="radio"
                id="first-rate4"
                name="review[rating]"
                value="4"
              />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input
                type="radio"
                id="first-rate5"
                name="review[rating]"
                value="5"
              />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label fw-bold">Comment</label>
            <textarea
              id="comment"
              rows="4"
              name="review[comment]"
              class="form-control"
              required
              placeholder="Share your experience..."
            ></textarea>
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">
              Please submit some comments for review
            </div>
          </div>
          <button class="btn btn-submit-review">Submit Review</button>
        </form>
      </div>
      <% } %> <% if(listing.reviews.length > 0) { %>
      <h4 class="review-section-title mt-5 mb-4">All Reviews</h4>
      <div class="row">
        <% for(let review of listing.reviews) { %>
        <div class="col-md-6 mb-4">
          <div class="card review-card h-100 shadow-sm border-0 bg-light">
            <div class="card-body">
              <div
                class="d-flex justify-content-between align-items-start mb-2"
              >
                <div>
                  <h5 class="card-title review-author m-0 fw-bold">
                    @<%= review.author.username %>
                  </h5>
                  <p
                    class="starability-result card-text mt-1"
                    data-rating="<%= review.rating %>"
                  ></p>
                </div>
                <% if(currUser && review.author._id.equals(currUser._id)) { %>
                <form
                  method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                >
                  <button class="btn-delete-review" title="Delete Review">
                    <i class="fas fa-trash-alt"></i>
                  </button>
                </form>
                <% } %>
              </div>
              <p class="card-text review-comment mt-2 text-muted">
                "<%= review.comment %>"
              </p>
            </div>
          </div>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>
</div>
